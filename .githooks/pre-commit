#!/bin/sh
# Auto-format staged Rust code before each commit, so commits go in rustfmt-clean
# and the pre-push backstop (cargo fmt --all -- --check) never trips.
#
# Commits stay manual: this only touches *.rs files you have already staged,
# formats them in place, and re-stages the result. It does not commit for you.
#
# Edition is passed explicitly because we invoke rustfmt directly (not via
# `cargo fmt`, which would reformat the whole workspace), and the workspace is
# edition 2024.
#
# Caveat: a partially staged file (some hunks staged, some not) gets fully
# re-staged after formatting, pulling in its unstaged hunks too. If you stage
# whole files, this never bites.
#
# Enable once per clone: git config core.hooksPath .githooks
set -e

files=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs')
[ -z "$files" ] && exit 0

echo "pre-commit: rustfmt on staged Rust files"
echo "$files" | xargs rustfmt --edition 2024
echo "$files" | xargs git add

# Reject NEW non-ASCII in Rust code. Typographic Unicode (arrows, dots, bullets, em-dashes, ellipses) that
# ends up in a string literal renders as unprintable glyphs in the app UI and in the debug logs, over and
# over. So code stays ASCII: use "->" not an arrow, "--" not an em-dash, "x" not a multiply sign, "*" not a
# bullet, "..." not an ellipsis. Only newly ADDED lines are checked, and // comments are exempt.
bad=$(git diff --cached --unified=0 -- '*.rs' \
  | grep -E '^\+' | grep -vE '^\+\+\+' \
  | sed -e 's@^+@@' -e 's@//.*@@' \
  | grep -nP '[^\x00-\x7F]' || true)
if [ -n "$bad" ]; then
  echo "pre-commit: BLOCKED - non-ASCII added in code (use ASCII in strings/logs, not typographic Unicode):"
  echo "$bad"
  echo "Replace with ASCII (-> -- x * ...), re-stage, and commit again."
  exit 1
fi
