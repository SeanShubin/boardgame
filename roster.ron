// Melee archetype catalog — five-stat chassis (might/vitality/toughness/speed/daring)
// + the deferred GEAR layer: per-type resistance (subtractive pre-pile cut, capped ≤3)
// and typed weapons. RPS is EMERGENT: each specialist resists its prey's damage type
// (pierce>slash>crush>pierce) — no counter table is written. A god carries all types
// and always strikes the defender's least-resisted (covers every weakness).
// All stats ≤9, resistance ≤3. Regenerate: cargo run -p combat-lab --bin combat_report
[
    // --- Core trio: the emergent cycle, equal chassis ---
    ( name: "Lancer", might: 6, weapon: [Pierce], vitality: 4, toughness: 4, speed: 2, daring: 2, resistance: (0, 3, 0) ),
    ( name: "Saber",  might: 6, weapon: [Slash],  vitality: 4, toughness: 4, speed: 2, daring: 2, resistance: (0, 0, 3) ),
    ( name: "Maul",   might: 6, weapon: [Crush],  vitality: 4, toughness: 4, speed: 2, daring: 2, resistance: (3, 0, 0) ),

    // --- Bruisers: big might, one slow action ---
    ( name: "Pike",    might: 8, weapon: [Pierce], vitality: 3, toughness: 4, speed: 1, daring: 2, resistance: (0, 3, 0) ),
    ( name: "Cleaver", might: 8, weapon: [Slash],  vitality: 3, toughness: 4, speed: 1, daring: 2, resistance: (0, 0, 3) ),
    ( name: "Hammer",  might: 8, weapon: [Crush],  vitality: 3, toughness: 4, speed: 1, daring: 2, resistance: (3, 0, 0) ),

    // --- Swarms: many fast weak hits, fragile ---
    ( name: "Gnat", might: 4, weapon: [Pierce], vitality: 6, toughness: 2, speed: 5, daring: 4, resistance: (0, 2, 0) ),
    ( name: "Hail", might: 4, weapon: [Slash],  vitality: 6, toughness: 2, speed: 5, daring: 4, resistance: (0, 0, 2) ),
    ( name: "Sand", might: 4, weapon: [Crush],  vitality: 6, toughness: 2, speed: 5, daring: 4, resistance: (2, 0, 0) ),

    // --- Tanks: high vitality/toughness, low might ---
    ( name: "Warden",  might: 4, weapon: [Pierce], vitality: 6, toughness: 5, speed: 2, daring: 2, resistance: (0, 3, 0) ),
    ( name: "Bulwark", might: 4, weapon: [Slash],  vitality: 6, toughness: 5, speed: 2, daring: 2, resistance: (0, 0, 3) ),

    // --- Keyword specialists ---
    ( name: "Reaver", might: 3, weapon: [Slash], vitality: 4, toughness: 3, speed: 3, daring: 3, resistance: (0, 0, 3), keywords: (persist: true) ),
    ( name: "Render", might: 6, weapon: [Crush], vitality: 4, toughness: 3, speed: 2, daring: 2, resistance: (3, 0, 0), keywords: (cleave: true) ),

    // --- The god: all damage types, balanced resistance (intended 1v1 outlier) ---
    ( name: "Paragon", might: 6, weapon: [Pierce, Slash, Crush], vitality: 5, toughness: 4, speed: 2, daring: 4, resistance: (2, 2, 2) ),
]
