    // --- Skirmishers: mid throughput, high initiative ---
    (
        name: "Pike",
        health_quantity: 4, health_magnitude: 3,
        armor: Mail,
        speed_quantity: 3, speed_magnitude: 6,
        weapons: [ (strike_magnitude: 3, channel: Pierce) ],
