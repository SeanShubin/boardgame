        armor: Plate,
        speed_quantity: 2, speed_magnitude: 2,
        weapons: [ (strike_magnitude: 6, channel: Slash) ],
    ),

    // --- Swarms: many fast weak hits; fragile cloth; differ by channel ---
    (
