// Melee archetype catalog — rebalanced for the multiplicative type chart.
// All stat numbers capped at 9, favouring low values (pre-god balancing).
// Goal: maximise distinct, viable, non-broken archetypes.
// Type chart: pierce>mail, slash>padded, crush>plate (×2); ×½ around the wheel.
// Regenerate: cargo run -p combat-lab --bin combat_report
[
    // --- Tanks: high Toughness wall, low offense; differ by armor/channel ---
    (
        name: "Bulwark",
        health_quantity: 5, health_magnitude: 6,
        armor: Plate,
        speed_quantity: 2, speed_magnitude: 2,
        weapons: [ (strike_magnitude: 3, channel: Slash) ],
    ),
    (
        name: "Warden",
        health_quantity: 5, health_magnitude: 6,
        armor: Mail,
        speed_quantity: 2, speed_magnitude: 2,
        weapons: [ (strike_magnitude: 3, channel: Pierce) ],
    ),
    (
        name: "Aegis",
        health_quantity: 5, health_magnitude: 6,
        armor: Padded,
        speed_quantity: 2, speed_magnitude: 2,
        weapons: [ (strike_magnitude: 3, channel: Crush) ],
    ),

    // --- Bruisers: big hits that crack high-Toughness tanks; slow ---
    (
        name: "Maul",
        health_quantity: 4, health_magnitude: 4,
        armor: Mail,
        speed_quantity: 2, speed_magnitude: 2,
        weapons: [ (strike_magnitude: 6, channel: Crush) ],
    ),
    (
